form   ::= cmp ion?
cmp    ::= term num?
         | cmp cmp
term   ::= elem
         | '(' cmp ')'
elem   ::= 'H'
         | 'He'
         | 'Li'
         | 'Be'
         | 'B'
         | 'C'
ion    ::= ionNum? ( '+' | '-' )
ionNum ::= '2'
         | '3'
         | '4'
num    ::= '1'
         | ionNum